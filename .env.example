# AI Content Agent - Environment Variables

# === AI ===
ANTHROPIC_API_KEY=sk-ant-xxxxx          # Claude API 키

# === Database ===
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_KEY=xxxxx

# === Google ===
GOOGLE_ANALYTICS_PROPERTY_ID=xxxxx
GOOGLE_ADSENSE_CLIENT_ID=xxxxx
GOOGLE_SEARCH_CONSOLE_SITE=xxxxx
GOOGLE_SERVICE_ACCOUNT_JSON=./config/google-sa.json

# === SNS ===
TWITTER_API_KEY=xxxxx
TWITTER_API_SECRET=xxxxx
TWITTER_ACCESS_TOKEN=xxxxx
TWITTER_ACCESS_SECRET=xxxxx

INSTAGRAM_ACCESS_TOKEN=xxxxx

# === Notification ===
SLACK_WEBHOOK_URL=xxxxx                 # 알림용 (선택)
KAKAO_REST_API_KEY=xxxxx               # 카카오톡 알림 (선택)

# === Site ===
SITE_URL=https://your-domain.com
SITE_NAME=your-site-name
